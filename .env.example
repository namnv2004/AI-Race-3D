# AI Race 3D local environment template.
# Copy to .env and fill local values as needed. Do not commit real secrets.

# Optional Hugging Face token for gated SAM checkpoints.
HF_TOKEN=

# Runtime knobs for local PyTorch/CUDA execution.
CUDA_VISIBLE_DEVICES=0
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# Current dataset split.
AI_RACE_ROUND=round1
AI_RACE_PHASE=phase1
AI_RACE_DATA_ROOT=data/round1/phase1
AI_RACE_PUBLIC_ROOT=data/round1/phase1/public_set
AI_RACE_PRIVATE_ROOT=data/round1/phase1/private_set1
AI_RACE_PUBLIC_SCENES=HCM0181,HCM0193,HCM0204,hcm0031,hcm0034
AI_RACE_PRIVATE_SCENES=HCM0249,HCM0254,HCM0276,HCM1439,HNI0131,HNI0265,HNI0366,HNI0437

# Local artifact roots.
AI_RACE_OUTPUTS_ROOT=outputs
AI_RACE_CHECKPOINTS_ROOT=checkpoints
AI_RACE_WORKSPACE_ROOT=workspace
AI_RACE_SUBMISSIONS_ROOT=submissions
AI_RACE_REPORTS_ROOT=reports
AI_RACE_MASK_ROOT=masks

# Third-party roots.
MIP_SPLATTING_ROOT=third_party/mip-splatting
TWODGS_ROOT=third_party/2d-gaussian-splatting
GSPLAT_SOURCE_ROOT=third_party/gsplat
